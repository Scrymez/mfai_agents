{
  "name": "gemini-vscode-agent",
  "displayName": "Gemini VS Code Agent",
  "description": "VS Code extension that connects Gemini API to a file-aware coding agent.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Other",
    "AI",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:geminiAgent.openChat",
    "onCommand:geminiAgent.openNativeChat",
    "onCommand:geminiAgent.resetSession",
    "onCommand:geminiAgent.setApiKey",
    "onCommand:geminiAgent.setBaseUrl",
    "onCommand:geminiAgent.clearApiKey",
    "onCommand:geminiAgent.clearBaseUrl",
    "onView:geminiAgent.sidebar",
    "onChatParticipant:local.gemini-vscode-agent"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "geminiAgent.openChat",
        "title": "Gemini Agent: Open Chat"
      },
      {
        "command": "geminiAgent.openNativeChat",
        "title": "Gemini Agent: Open Native Chat"
      },
      {
        "command": "geminiAgent.resetSession",
        "title": "Gemini Agent: Reset Session"
      },
      {
        "command": "geminiAgent.setApiKey",
        "title": "Gemini Agent: Set API Key"
      },
      {
        "command": "geminiAgent.setBaseUrl",
        "title": "Gemini Agent: Set Base URL"
      },
      {
        "command": "geminiAgent.clearApiKey",
        "title": "Gemini Agent: Clear API Key"
      },
      {
        "command": "geminiAgent.clearBaseUrl",
        "title": "Gemini Agent: Clear Base URL"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "geminiAgent",
          "title": "Gemini Agent",
          "icon": "media/gemini.svg"
        }
      ]
    },
    "views": {
      "geminiAgent": [
        {
          "type": "webview",
          "id": "geminiAgent.sidebar",
          "name": "Chat"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "local.gemini-vscode-agent",
        "name": "gemini",
        "fullName": "Gemini Agent",
        "description": "Ask Gemini to inspect and edit files in your workspace.",
        "isSticky": true
      }
    ],
    "configuration": {
      "title": "Gemini Agent",
      "properties": {
        "geminiAgent.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Gemini API key. If empty, the extension will also check the `GEMINI_API_KEY` environment variable."
        },
        "geminiAgent.apiStyle": {
          "type": "string",
          "default": "gemini",
          "enum": [
            "gemini",
            "openai-compatible"
          ],
          "description": "Choose the native Gemini API or an OpenAI-compatible endpoint such as Timeweb Cloud AI agents."
        },
        "geminiAgent.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for OpenAI-compatible mode, for example a Timeweb OpenAI URL without the trailing /v1/chat/completions part."
        },
        "geminiAgent.model": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "Gemini model passed to the generateContent API."
        },
        "geminiAgent.allowOutsideWorkspace": {
          "type": "boolean",
          "default": false,
          "description": "Allow the agent to read and write absolute paths outside the currently opened workspace."
        },
        "geminiAgent.confirmDangerousWrites": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before overwriting files or writing outside the current workspace."
        },
        "geminiAgent.maxFileBytes": {
          "type": "number",
          "default": 200000,
          "minimum": 4096,
          "description": "Maximum file size the agent can read in one tool call."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "geminiAgent.setApiKey",
          "when": "view == geminiAgent.sidebar",
          "group": "navigation"
        },
        {
          "command": "geminiAgent.setBaseUrl",
          "when": "view == geminiAgent.sidebar",
          "group": "navigation"
        },
        {
          "command": "geminiAgent.resetSession",
          "when": "view == geminiAgent.sidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
